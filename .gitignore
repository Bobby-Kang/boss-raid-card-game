# Godot 4+ specific ignores
.godot/
/android/

# Godot import files
*.import
# 단, 폰트 import는 MSDF 등 필수 설정을 담으므로 추적
!assets/fonts/*.import

# Claude Code
.claude/

# OS
Thumbs.db
.DS_Store

# IDE
.vscode/
*.swp
*.swo

# Temp files
*.tmp

# 빌드 산출물 (export)
/build/
# 루트에 직접 export된 경우 (export_path=./)
/*.exe
/index.html
/index.js
/index.wasm
/index.pck
/index.png
/index.icon.png
/index.apple-touch-icon.png
/index.audio.worklet.js
/index.audio.position.worklet.js

# Python (tools/)
__pycache__/
*.pyc

# 구매/다운로드한 서드파티 에셋 팩 — 재배포 금지 조항이 있어 저장소에 넣지 않는다.
# 각 팩의 출처와 라이선스는 CREDITS.md에 기록. 받는 방법은 assets/art/packs/README.md 참고.
assets/art/packs/*
!assets/art/packs/README.md
