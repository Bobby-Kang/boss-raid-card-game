## ================================================================
## game_balance.gd — 게임 밸런스 수치 모음
## ================================================================
##
## 여기에 있는 숫자만 바꿔도 게임 느낌이 달라집니다.
## 다른 파일을 찾아다닐 필요가 없어요.
##
## 사용 예시:
##   GameBalance.PLAYER_MAX_HP      → 50
##   GameBalance.BOSS_MAX_HP        → 100
##   GameBalance.RAGE_BURST_DAMAGE  → 10

class_name GameBalance


# ─── 플레이어 ─────────────────────────────────────────────────────
const PLAYER_MAX_HP     := 50   ## 플레이어 최대 체력
const PLAYER_DRAW_COUNT := 5    ## 플레이어 턴마다 손에 드로우하는 카드 수


# ─── 라운드 ───────────────────────────────────────────────────────
const TURNS_PER_ROUND   := 4    ## 라운드당 턴 수 (P→B 교대, 짝수 권장)


# ─── 자원 ─────────────────────────────────────────────────────────
const AP_MAX            := 3    ## 최대 AP — 플레이어 턴 시작 시 이 값으로 완전 리셋
const GOLD_MAX          := 10   ## 최대 골드 — 턴 종료 시 전량 증발


# ─── 보스 ─────────────────────────────────────────────────────────
const BOSS_MAX_HP       := 100  ## 보스 최대 체력


# ─── 전사: 투기 발산 ───────────────────────────────────────────────
const RAGE_MAX_STACKS   := 10   ## 투기 최대 스택 (이 수치 도달 시 발동 버튼 활성화)
const RAGE_BURST_DAMAGE := 10   ## 투기 발산 시 보스에게 주는 피해
const RAGE_BURST_BLOCK  := 10   ## 투기 발산 시 획득하는 방어도


# ─── 마켓 ─────────────────────────────────────────────────────────
const MARKET_REROLL_AP   := 3   ## 마켓 전체 리롤 AP 비용
const MARKET_REROLL_GOLD := 3   ## 마켓 전체 리롤 골드 비용
